# --- DATABASE (PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Note: Use 'infra_db' when running inside Docker, 'localhost' if running Node locally.
# Update this to use 'postgres' as the user and 'localhost' as the host
DATABASE_URL="postgresql://postgres:password@localhost:5432/matchpolls"

# --- REDIS ---
# Use 'infra_redis' for Docker, 'localhost' for local development.
REDIS_URL="redis://infra_redis:6379"

# --- SERVICE PORTS ---
GATEWAY_PORT=8080
ROOM_SERVICE_PORT=3001
POLL_SERVICE_PORT=3002

# --- POSTGRES INFRA (Used by docker-compose) ---
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=matchpolls